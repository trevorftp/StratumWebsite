---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const sections = [
  {
    title: 'Developers',
    description: 'Developers build and maintain Stratum. They own the codebase, make architectural decisions, and are responsible for the features and fixes that ship in every release.',
    members: [
      { name: 'Trevor', handle: 'trevorftp', discord: 'imtsubaki' },
    ],
  },
  {
    title: 'Community Team',
    description: 'The community team keeps our spaces running and helps server owners get set up. They handle support and moderation across the Discord and make sure everyone gets the help they need.',
    members: [
      { name: 'PHoenixOPHury', handle: 'PHoenixOPHury', discord: 'phoenixophury' },
    ],
  },
  {
    title: 'Contributors',
    description: 'Contributors have put real work into Stratum by submitting patches, fixing bugs, and improving performance. They are the reason certain features exist or run better than they did before.',
    members: [
      { name: 'tehtelev', handle: 'tehtelev', discord: 'havel7286' },
      { name: 'Garward', handle: 'Garward', discord: 'garward' },
      { name: 'Zaldaryon', handle: 'Zaldaryon', discord: 'zaldaryon' },
    ],
  },
];
---

<Base title="Team" description="The people behind Stratum.">
  <Nav />

  <main class="mx-auto max-w-5xl px-6 py-20">
    <h1 class="mb-3 text-3xl font-bold text-stone-100">Team</h1>
    <p class="mb-16 text-stone-400">The people building and supporting Stratum.</p>

    <div class="space-y-14">
      {sections.map(section => (
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-widest text-stone-500">{section.title}</h2>
          <p class="mt-1 mb-6 text-sm text-stone-400">{section.description}</p>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {section.members.map(member => (
              <div class="rounded-xl border border-stone-800 bg-stone-900 p-5">
                <div class="flex items-center gap-3 mb-4">
                  <img
                    src={`https://github.com/${member.handle}.png?size=96`}
                    alt={member.name}
                    width="44"
                    height="44"
                    class="rounded-full bg-stone-800"
                  />
                  <div>
                    <p class="font-semibold text-stone-100">{member.name}</p>
                    <p class="text-xs text-stone-500">@{member.handle}</p>
                  </div>
                </div>
                <div class="flex items-center gap-4">
                  <a
                    href={`https://github.com/${member.handle}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-1.5 text-xs text-stone-400 hover:text-stone-100 transition-colors"
                  >
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                    </svg>
                    GitHub
                  </a>
                  <span class="flex items-center gap-1.5 text-xs text-stone-500">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.031.055a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 13.995 13.995 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
                    </svg>
                    {member.discord}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 flex flex-col gap-4 rounded-xl border border-stone-800 bg-stone-900/40 p-8 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="font-semibold text-stone-100">Want to get involved?</h2>
        <p class="mt-1 text-sm text-stone-400">Code, bug reports, community help, and financial support are all welcome.</p>
      </div>
      <a
        href="/contribute"
        class="shrink-0 rounded-md bg-amber-500 px-5 py-2.5 text-sm font-semibold text-stone-950 transition-colors hover:bg-amber-400"
      >
        See how to contribute
      </a>
    </div>
  </main>

  <Footer />
</Base>
